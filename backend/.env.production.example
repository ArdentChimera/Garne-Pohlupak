# Production Environment Variables Template
# Copy this to .env.production and fill in your actual values

# Server Configuration
PORT=8080
NODE_ENV=production

# Database - Neon PostgreSQL
DATABASE_URL=your_neon_database_url_here

# JWT Secret - Generate a strong random string
JWT_SECRET=your_super_secret_jwt_key_here

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL - This will be your Firebase Hosting URL
FRONTEND_URL=https://your-app.web.app

# CORS Origins - Comma separated if multiple
CORS_ORIGINS=https://your-app.web.app,https://your-app.firebaseapp.com
